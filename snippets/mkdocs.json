{
  "Admonition": {
    "prefix": "!!!",
    "body": [
      "!!! ${1|note,info,tip,success,question,warning,danger,example,quote,propriete,definition,methode,remarque|} \"${2:Title}\"",
      "",
      "    ${0:Admonition content}"
    ],
    "description": "MkDocs admonition (Material / pymdownx)"
  },
  "Collapsible admonition": {
    "prefix": "???",
    "body": [
      "???${1|+,|} ${2|note,info,tip,warning,danger,example,question,propriete,definition|} \"${3:Title}\"",
      "",
      "    ${0:Collapsible content}"
    ],
    "description": "Collapsible admonition (??? closed, ???+ open)"
  },
  "Math block": {
    "prefix": "math",
    "body": [
      "$$",
      "${0}",
      "$$"
    ],
    "description": "Math block (arithmatex)"
  },
  "Content tabs": {
    "prefix": "===",
    "body": [
      "=== \"${1:Tab 1}\"",
      "",
      "    ${2:Content}",
      "",
      "=== \"${3:Tab 2}\"",
      "",
      "    ${0:Content}"
    ],
    "description": "Content tabs (pymdownx.tabbed)"
  },
  "Captioned image": {
    "prefix": "fig",
    "body": [
      "![${1:alt text}](${2:path}){${3:.center}}",
      "/// caption",
      "${0:Caption}",
      "///"
    ],
    "description": "Image with caption (pymdownx.blocks.caption)"
  }
}
